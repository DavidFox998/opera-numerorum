modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lean-proof"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "kernel-numerics"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "theorema-certs-e2e"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "morningstar-tamper"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "lake-recovery-test"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Forensic Dump"

[[workflows.workflow]]
name = "lean-proof"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "STRICT_LEAN_CHECK=1 ./scripts/check-lean-proof.sh"

[[workflows.workflow]]
name = "kernel-numerics"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_kernel.py -q"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "theorema-certs-e2e"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "STRICT_E2E_CHECK=1 bash scripts/check-theorema-certs-e2e.sh"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "morningstar-tamper"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_morningstar.py tests/test_reroll_checkpoint_script.py -q"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "lake-recovery-test"
author = "agent"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python -m pytest tests/test_restore_lake_git_script.py tests/test_ensure_mathlib_cache_bin_script.py tests/test_fetch_mathlib_oleans_script.py -q"

[[workflows.workflow]]
name = "Forensic Dump"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash make_s4.sh"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 180000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 8081

[[ports]]
localPort = 8082
externalPort = 3000

[[ports]]
localPort = 8083
externalPort = 3001

[[ports]]
localPort = 23179
externalPort = 80

[[ports]]
localPort = 23180
externalPort = 3003

[nix]
channel = "stable-25_05"
packages = ["freetype", "glibcLocales", "lcms2", "libimagequant", "libjpeg", "libtiff", "libwebp", "libxcrypt", "openjpeg", "tcl", "tesseract", "tk", "zlib"]
